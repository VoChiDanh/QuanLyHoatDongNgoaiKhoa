@model IEnumerable<QL_HDNK.Models.TrangThaiDiemDanh>

@{
    ViewBag.Title = "Danh sách";
}

<h2>Danh sách</h2>

<p>
    @Html.ActionLink("Thêm mới", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.TenTTDD)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.TenTTDD)
        </td>
        <td>
            @Html.ActionLink("Sửa", "Edit", new { id=item.MaTTDD }) |
            @Html.ActionLink("Chi tiết", "Details", new { id=item.MaTTDD }) |
            @Html.ActionLink("Xóa", "Delete", new { id=item.MaTTDD })
        </td>
    </tr>
}

</table>



