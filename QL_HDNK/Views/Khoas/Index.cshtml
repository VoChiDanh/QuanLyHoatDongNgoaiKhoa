@model IEnumerable<QL_HDNK.Models.Khoa>

@{
    ViewBag.Title = "Danh sách";
}

<h2>Danh sách</h2>

<p>
    @Html.ActionLink("Thêm mới", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.TenKhoa)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.TenKhoa)
        </td>
        <td>
            @Html.ActionLink("Sửa", "Edit", new { id=item.MaKhoa }) |
            @Html.ActionLink("Chi tiết", "Details", new { id=item.MaKhoa }) |
            @Html.ActionLink("Xóa", "Delete", new { id=item.MaKhoa })
        </td>
    </tr>
}

</table>



