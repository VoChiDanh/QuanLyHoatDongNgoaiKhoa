@model IEnumerable<QL_HDNK.Models.NguoiDung>
@using QL_HDNK.Filters

@{
    ViewBag.Title = "Quản lý người dùng";
    
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 15;
    
    string currentSearch = ViewBag.CurrentSearch;
    string currentMaKhoa = ViewBag.CurrentMaKhoa;
    string currentMaLop = ViewBag.CurrentMaLop;
    string currentMaQuyen = ViewBag.CurrentMaQuyen;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

<main class="module-page user-admin-page">
    <div class="page-heading">
        <div>
            <span class="eyebrow text-muted">Hệ thống</span>
            <h1 class="h2 fw-bold text-primary m-0">Danh sách người dùng</h1>
            <p class="text-muted m-0">Quản lý tài khoản người dùng, phân quyền hệ thống và đồng bộ dữ liệu sinh viên.</p>
        </div>
        <div class="event-summary-strip">
            <span>Tổng cộng: <strong>@totalItems</strong> tài khoản</span>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Panel Lọc và Tìm Kiếm -->
    <div class="event-filter-panel mb-3">
        @using (Html.BeginForm("Index", "NguoiDungs", FormMethod.Get, new { @class = "event-filter-grid", id = "filterForm" }))
        {
            <div>
                <label class="form-label fw-semibold text-muted small">Tìm kiếm</label>
                <input type="text" name="search" class="form-control" value="@currentSearch" placeholder="Nhập MSSV, Họ tên, Email..." />
            </div>
            <div>
                <label class="form-label fw-semibold text-muted small">Khoa</label>
                @Html.DropDownList("maKhoa", (SelectList)ViewBag.MaKhoa, "--- Tất cả ---", new { @class = "form-select", id = "maKhoaSelect" })
            </div>
            <div>
                <label class="form-label fw-semibold text-muted small">Lớp</label>
                @Html.DropDownList("maLop", (SelectList)ViewBag.MaLop, "--- Tất cả ---", new { @class = "form-select", id = "maLopSelect" })
            </div>
            <div>
                <label class="form-label fw-semibold text-muted small">Quyền hạn</label>
                @Html.DropDownList("maQuyen", (SelectList)ViewBag.MaQuyen, "--- Tất cả ---", new { @class = "form-select", id = "maQuyenSelect" })
            </div>
            <div class="event-filter-actions">
                <button type="submit" class="btn btn-primary px-3">Lọc</button>
                <a href="@Url.Action("Index", "NguoiDungs")" class="btn btn-outline-secondary px-3" title="Xóa bộ lọc">Xóa</a>
            </div>
        }
    </div>

    <!-- Nút hành động chính -->
    <div class="d-flex gap-2 justify-content-end mb-3">
        @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-primary" })
        @Html.ActionLink("Đồng bộ từ Excel", "ImportExcel", null, new { @class = "btn btn-success" })
    </div>

    <!-- Bảng người dùng -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 15%;">MSSV / ID</th>
                        <th style="width: 25%;">Họ và tên</th>
                        <th style="width: 25%;">Liên hệ & Ngày sinh</th>
                        <th style="width: 15%;">Lớp học</th>
                        <th style="width: 10%;">Quyền hạn</th>
                        <th style="width: 10%;" class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var normalizedRole = RoleHelper.Normalize(item.MaQuyen, item.QuyenHan != null ? item.QuyenHan.TenQuyen : "");
                            var badgeClass = "bg-secondary";
                            
                            if (normalizedRole == RoleKeys.Admin)
                            {
                                badgeClass = "bg-danger text-white";
                            }
                            else if (normalizedRole == RoleKeys.FacultyUnion)
                            {
                                badgeClass = "bg-warning text-dark";
                            }
                            else if (normalizedRole == RoleKeys.ClassOfficer)
                            {
                                badgeClass = "bg-info text-dark";
                            }

                            <tr>
                                <td>
                                    <span class="fw-bold font-monospace text-secondary">
                                        @(string.IsNullOrEmpty(item.MaSinhVien) ? item.MaNguoiDung : item.MaSinhVien)
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.HoTen</div>
                                </td>
                                <td>
                                    <div class="text-dark small"><i class="bi bi-envelope me-1 text-muted"></i>@item.Email</div>
                                    @if (item.NgaySinh.HasValue)
                                    {
                                        <div class="text-muted small mt-1">
                                            <i class="bi bi-calendar me-1"></i>@item.NgaySinh.Value.ToString("dd/MM/yyyy")
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (item.LopHoc != null)
                                    {
                                        <div class="fw-semibold">@item.LopHoc.TenLop</div>
                                        <div class="text-muted small" style="font-size: 0.8em;">
                                            @(item.LopHoc.Khoa != null ? item.LopHoc.Khoa.TenKhoa : "")
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Không có</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @badgeClass">
                                        @(item.QuyenHan != null ? item.QuyenHan.TenQuyen : "Chưa phân quyền")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a href="@Url.Action("Edit", new { id = item.MaNguoiDung })" class="btn btn-sm btn-outline-primary" title="Sửa"><i class="bi bi-pencil me-1"></i>Sửa</a>
                                        <a href="@Url.Action("Details", new { id = item.MaNguoiDung })" class="btn btn-sm btn-outline-info" title="Chi tiết"><i class="bi bi-info-circle me-1"></i>Chi tiết</a>
                                        <a href="@Url.Action("Delete", new { id = item.MaNguoiDung })" class="btn btn-sm btn-outline-danger" title="Xóa"><i class="bi bi-trash me-1"></i>Xóa</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                Không tìm thấy người dùng nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Phân trang -->
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
            <div class="text-muted small">
                Hiển thị từ <strong>@((currentPage - 1) * pageSize + 1)</strong> đến <strong>@(Math.Min(currentPage * pageSize, totalItems))</strong> trong tổng số <strong>@totalItems</strong> người dùng.
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm m-0">
                    <!-- Nút Trước -->
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { search = currentSearch, maKhoa = currentMaKhoa, maLop = currentMaLop, maQuyen = currentMaQuyen, page = currentPage - 1 })" aria-label="Trước">
                            <span aria-hidden="true">&laquo; Trước</span>
                        </a>
                    </li>

                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { search = currentSearch, maKhoa = currentMaKhoa, maLop = currentMaLop, maQuyen = currentMaQuyen, page = 1 })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(currentPage == i ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { search = currentSearch, maKhoa = currentMaKhoa, maLop = currentMaLop, maQuyen = currentMaQuyen, page = i })">@i</a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { search = currentSearch, maKhoa = currentMaKhoa, maLop = currentMaLop, maQuyen = currentMaQuyen, page = totalPages })">@totalPages</a>
                        </li>
                    }

                    <!-- Nút Sau -->
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { search = currentSearch, maKhoa = currentMaKhoa, maLop = currentMaLop, maQuyen = currentMaQuyen, page = currentPage + 1 })" aria-label="Sau">
                            <span aria-hidden="true">Sau &raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</main>

@section scripts {
    <script>
        $(document).ready(function () {
            // Khi thay đổi Khoa, reset lựa chọn Lớp học
            $('#maKhoaSelect').change(function () {
                $('#maLopSelect').val('');
                $('#filterForm').submit();
            });

            // Tự động submit form khi chọn Lớp hoặc Quyền hạn
            $('#maLopSelect, #maQuyenSelect').change(function () {
                $('#filterForm').submit();
            });
        });
    </script>
}
