@{
    ViewBag.Title = "Không có quyền truy cập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex flex-column justify-content-center align-items-center mt-5" style="min-height: 60vh;">
    <div class="text-center bg-white p-5 rounded shadow-sm" style="max-width: 600px; width: 100%;">
        <div class="mb-4">
            <i class="fas fa-lock text-warning" style="font-size: 6rem; drop-shadow: 0 4px 6px rgba(0,0,0,0.1);"></i>
        </div>
        <h1 class="display-5 fw-bold text-dark mb-3">Truy cập bị từ chối</h1>
        
        <div class="alert alert-warning fs-5 mb-4" role="alert">
            Bạn không có quyền xem hoặc thực hiện chức năng này.
        </div>

        <p class="text-muted mb-5">
            Tài khoản hiện tại chưa được cấp quyền hạn cần thiết. Vui lòng liên hệ với ban quản trị hoặc giảng viên phụ trách nếu bạn cần cấp thêm quyền.
        </p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <button onclick="history.back()" class="btn btn-outline-secondary px-4 py-2 fw-semibold">
                <i class="fas fa-arrow-left me-2"></i>Quay lại
            </button>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2 fw-semibold">
                <i class="fas fa-home me-2"></i>Về trang chủ
            </a>
        </div>
    </div>
</div>
