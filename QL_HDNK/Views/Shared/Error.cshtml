@model System.Web.Mvc.HandleErrorInfo

@{
    ViewBag.Title = "Thông báo lỗi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container d-flex flex-column justify-content-center align-items-center mt-5" style="min-height: 60vh;">
    <div class="text-center bg-white p-5 rounded shadow-sm" style="max-width: 600px; width: 100%;">
        <div class="mb-4">
            <i class="fas fa-exclamation-triangle text-danger" style="font-size: 6rem; drop-shadow: 0 4px 6px rgba(0,0,0,0.1);"></i>
        </div>
        <h1 class="display-5 fw-bold text-danger mb-3">Đã xảy ra sự cố!</h1>
        
        <div class="alert alert-danger fs-5 mb-4" role="alert">
            @if (ViewBag.ErrorMessage != null)
            {
                @ViewBag.ErrorMessage
            }
            else if (Model != null && Model.Exception != null)
            {
                @Model.Exception.Message
            }
            else
            {
                <text>Yêu cầu của bạn không hợp lệ hoặc đã xảy ra lỗi trong quá trình xử lý.</text>
            }
        </div>

        <p class="text-muted mb-5">Vui lòng thử lại sau hoặc liên hệ với quản trị viên nếu vấn đề vẫn tiếp diễn.</p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <button onclick="history.back()" class="btn btn-outline-secondary px-4 py-2 fw-semibold">
                <i class="fas fa-arrow-left me-2"></i>Quay lại
            </button>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2 fw-semibold">
                <i class="fas fa-home me-2"></i>Về trang chủ
            </a>
        </div>
    </div>
</div>
