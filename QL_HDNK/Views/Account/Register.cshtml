@model QL_HDNK.Models.RegisterViewModel

@{
    ViewBag.Title = "Đăng ký";
}

<main class="auth-page" aria-labelledby="title">
    <section class="auth-card wide">
        <span class="eyebrow">Tài khoản sinh viên</span>
        <h1 id="title">Đăng ký tài khoản</h1>
        <p class="lead">Tài khoản mới mặc định được gán quyền sinh viên để tra cứu sự kiện, đăng ký tham gia và theo dõi điểm rèn luyện.</p>

        @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "auth-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-grid">
                <div class="form-group">
                    @Html.LabelFor(model => model.MaSinhVien, htmlAttributes: new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.MaSinhVien, new { @class = "form-control", autocomplete = "username" })
                    @Html.ValidationMessageFor(model => model.MaSinhVien, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.HoTen, htmlAttributes: new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.HoTen, new { @class = "form-control", autocomplete = "name" })
                    @Html.ValidationMessageFor(model => model.HoTen, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.Email, new { @class = "form-control", autocomplete = "email", type = "email" })
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.NgaySinh, htmlAttributes: new { @class = "control-label" })
                    @Html.TextBoxFor(model => model.NgaySinh, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    @Html.ValidationMessageFor(model => model.NgaySinh, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.MaLop, htmlAttributes: new { @class = "control-label" })
                    @Html.DropDownList("MaLop", null, "Chọn lớp", htmlAttributes: new { @class = "form-control" })
                    @Html.ValidationMessageFor(model => model.MaLop, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.MatKhau, htmlAttributes: new { @class = "control-label" })
                    @Html.PasswordFor(model => model.MatKhau, new { @class = "form-control", autocomplete = "new-password" })
                    @Html.ValidationMessageFor(model => model.MatKhau, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.XacNhanMatKhau, htmlAttributes: new { @class = "control-label" })
                    @Html.PasswordFor(model => model.XacNhanMatKhau, new { @class = "form-control", autocomplete = "new-password" })
                    @Html.ValidationMessageFor(model => model.XacNhanMatKhau, "", new { @class = "text-danger" })
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg">Tạo tài khoản</button>
        }

        <div class="auth-switch">
            Đã có tài khoản? @Html.ActionLink("Đăng nhập", "Login", "Account")
        </div>
    </section>
</main>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

